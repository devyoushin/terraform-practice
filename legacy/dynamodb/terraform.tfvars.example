###############################################
# terraform.tfvars.example
# 이 파일을 참고하여 각 환경의 terraform.tfvars를 작성하세요.
# cp terraform.tfvars.example envs/dev/terraform.tfvars
###############################################

aws_region   = "ap-northeast-2"
project_name = "my-project"   # ← 프로젝트 이름 입력
owner        = "infra-team"   # ← 담당자/팀 이름 입력

# -----------------------------------------------
# 테이블 설정
# -----------------------------------------------
table_suffix = "sessions"   # ← 용도 입력 (예: sessions, locks, events, cache)
hash_key     = "id"         # ← 파티션 키 이름 (생성 후 변경 불가)
# range_key  = "created_at" # 정렬 키 (선택, 생성 후 변경 불가)

attributes = [
  { name = "id", type = "S" },
  # { name = "created_at", type = "S" },
]

# -----------------------------------------------
# 빌링 모드 (dev/staging: PAY_PER_REQUEST 권장)
# -----------------------------------------------
billing_mode = "PAY_PER_REQUEST"

# -----------------------------------------------
# prod 권장 옵션
# -----------------------------------------------
# deletion_protection = true    # prod: 실수로 삭제 방지
# enable_pitr         = true    # prod: 35일 이내 시점 복구

# -----------------------------------------------
# TTL (선택 - 자동 항목 만료)
# -----------------------------------------------
# ttl_attribute = "expires_at"  # Unix timestamp 속성명

# -----------------------------------------------
# KMS 암호화 (선택)
# -----------------------------------------------
# kms_key_arn = "arn:aws:kms:ap-northeast-2:123456789012:key/xxxxxxxx"
