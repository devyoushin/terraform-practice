###############################################
# terraform.tfvars.example
# 이 파일을 참고하여 각 환경의 terraform.tfvars를 작성하세요.
# cp terraform.tfvars.example envs/dev/terraform.tfvars
###############################################

aws_region   = "ap-northeast-2"
project_name = "my-project"   # ← 프로젝트 이름 입력
owner        = "infra-team"   # ← 담당자/팀 이름 입력

# -----------------------------------------------
# 알람 알림 (선택)
# -----------------------------------------------
# enable_alarm_notification = true
# alarm_email               = "infra@example.com"   # ← 수신 이메일

# -----------------------------------------------
# 로그 그룹 (선택)
# -----------------------------------------------
# log_groups = [
#   { name = "/app/my-project/api",    retention_days = 30 },
#   { name = "/app/my-project/worker", retention_days = 14 },
# ]

# -----------------------------------------------
# 메트릭 알람 예시 (선택)
# -----------------------------------------------
# metric_alarms = [
#   {
#     alarm_name          = "high-cpu"
#     description         = "EC2 CPU 사용률 80% 초과"
#     comparison_operator = "GreaterThanThreshold"
#     evaluation_periods  = 2
#     metric_name         = "CPUUtilization"
#     namespace           = "AWS/EC2"
#     period              = 300
#     statistic           = "Average"
#     threshold           = 80
#     dimensions          = { InstanceId = "i-xxxxxxxxxxxxxxxxx" }
#   }
# ]

# -----------------------------------------------
# 대시보드 (선택)
# -----------------------------------------------
# enable_dashboard = false   # prod: true 권장

# -----------------------------------------------
# KMS 암호화 (선택)
# -----------------------------------------------
# kms_key_arn = "arn:aws:kms:ap-northeast-2:123456789012:key/xxxxxxxx"
