###############################################
# terraform.tfvars.example
# 이 파일을 참고하여 각 환경의 terraform.tfvars를 작성하세요.
# cp terraform.tfvars.example envs/dev/terraform.tfvars
###############################################

aws_region   = "ap-northeast-2"
project_name = "my-project"   # ← 프로젝트 이름 입력
owner        = "infra-team"   # ← 담당자/팀 이름 입력

# -----------------------------------------------
# 레포지토리 설정
# -----------------------------------------------
name_suffix = "app"   # ← 용도 입력 (예: app, api, worker, frontend)

# 이미지 태그 변경 가능 여부
# dev/staging: MUTABLE (빠른 반복 개발)
# prod:        IMMUTABLE (불변성 보장, 롤백 안정성)
# image_tag_mutability = "MUTABLE"

# -----------------------------------------------
# 수명주기 정책 (오래된 이미지 자동 삭제)
# -----------------------------------------------
# enable_lifecycle_policy = true
# untagged_image_days     = 14   # 태그 없는 이미지 보존 기간 (일)
# tagged_image_count      = 30   # 태그 있는 이미지 최대 보존 수

# -----------------------------------------------
# prod 권장 옵션
# -----------------------------------------------
# force_delete = false   # prod: 이미지 있어도 강제 삭제 방지

# -----------------------------------------------
# KMS 암호화 (선택)
# -----------------------------------------------
# encryption_type = "KMS"
# kms_key_arn     = "arn:aws:kms:ap-northeast-2:123456789012:key/xxxxxxxx"
