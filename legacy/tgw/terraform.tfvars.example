# =================================================================
# terraform.tfvars 예시 파일
#
# [사용 방법]
#   cp terraform.tfvars.example terraform.tfvars
#   terraform.tfvars 를 열어 "[변경]" 표시된 값을 실제 값으로 교체
#
# [주의] terraform.tfvars 는 .gitignore 에 추가 권장
#        (실제 리소스 ID, 계정 정보 포함)
# =================================================================

# ── 기본 설정 ────────────────────────────────────────────────────
# [변경] 리소스를 배포할 AWS 리전
# 서울: ap-northeast-2 / 도쿄: ap-northeast-1 / 버지니아: us-east-1
aws_region = "ap-northeast-2"

# [변경] 회사/프로젝트명 → 리소스 이름에 접두어로 사용됨
# 예: "acme" → TGW 이름이 "acme-prod-tgw" 로 생성됨
project = "mycompany"

# [변경] 배포 환경. prod / staging / dev 중 하나만 입력 가능
environment = "prod"


# ── Transit Gateway 설정 ─────────────────────────────────────────
# BGP ASN: TGW의 고유 식별 번호. 사설 ASN 범위(64512~65534) 사용.
# 같은 계정에 TGW를 여러 개 만들 경우 각각 다른 ASN을 써야 합니다.
# [변경] 다른 TGW나 온프레미스 장비와 ASN이 겹치면 안 됩니다.
tgw_amazon_side_asn = 64512

# RAM 공유된 어태치먼트 자동 수락 여부.
# true: 다른 계정에서 보낸 연결 요청을 자동으로 수락 (보안 위험 있음)
# false: 수동으로 수락 (운영 환경 권장)
tgw_auto_accept_shared_attachments = false

# 기본 라우트 테이블 자동 연결/전파 여부.
# false 권장: 아래에서 직접 라우트 테이블을 정의하고 수동으로 연결하기 때문.
# true로 하면 AWS가 알아서 하나의 기본 테이블에 모든 VPC를 연결시켜
# VPC 간 트래픽 격리가 불가능해집니다.
tgw_default_route_table_association = false
tgw_default_route_table_propagation = false

# DNS 지원: VPC의 프라이빗 DNS를 TGW 너머에서도 해석 가능하게 함. true 권장.
tgw_dns_support = true

# VPN ECMP: 동일 목적지에 대해 여러 VPN 터널로 부하 분산. true 권장.
tgw_vpn_ecmp_support = true

# 멀티캐스트: 1:N 트래픽이 필요한 경우(예: 미디어 스트리밍)에만 true.
# 한번 활성화하면 TGW를 삭제하지 않는 한 비활성화 불가.
tgw_multicast_support = false


# ── TGW 라우트 테이블 정의 ───────────────────────────────────────
# VPC 유형별로 라우트 테이블을 분리하면 환경 간 트래픽을 정밀하게 제어할 수 있습니다.
# 키 이름(shared, prod 등)은 아래 vpc_attachments의 route_table_key와 반드시 일치해야 합니다.
#
# [변경] 환경 구성에 맞게 라우트 테이블을 추가/제거하세요.
# 최소 구성: spoke 하나, shared 하나
tgw_route_tables = {
  shared = { name = "rt-shared" } # 공유 서비스 VPC용 (DNS, 모니터링, 패치 서버 등)
  egress = { name = "rt-egress" } # 인터넷 출구 VPC용 (NAT Gateway 집중화 시 사용)
  prod   = { name = "rt-prod" }   # 운영 환경 Spoke VPC용
  dev    = { name = "rt-dev" }    # 개발 환경 Spoke VPC용
}


# ── VPC 어태치먼트 ───────────────────────────────────────────────
# TGW에 연결할 VPC 목록입니다.
# 키 이름(shared, prod 등)은 라우트 전파/정적 경로 설정에서 attachment_key로 참조됩니다.
#
# [주의] subnet_ids는 반드시 "TGW 전용 서브넷"을 사용하세요.
#   - 권장: AZ당 /28 서브넷 (16개 IP, TGW가 1개 사용)
#   - 각 AZ마다 1개씩, 고가용성을 위해 최소 2개 AZ에 배치
#   - TGW 서브넷에는 다른 리소스(EC2 등)를 배치하지 않는 것이 좋습니다.
#
# [확인 방법] AWS 콘솔 → VPC → 서브넷 → Subnet ID 복사
#             또는: aws ec2 describe-subnets --filters "Name=tag:Name,Values=*tgw*"
vpc_attachments = {

  # ── Shared(Hub) VPC ──
  shared = {
    # [변경] 공유 서비스 VPC의 ID (vpc-로 시작하는 값)
    vpc_id = "vpc-0xxxxxxxxxxxxxxx1"

    # [변경] TGW 전용 서브넷 ID 목록 (AZ별로 1개씩, 최소 2개)
    subnet_ids = ["subnet-0xxxxxxx1", "subnet-0xxxxxxx2", "subnet-0xxxxxxx3"]

    # 위에서 정의한 tgw_route_tables의 키 이름과 일치해야 합니다.
    route_table_key = "shared"

    # ── VPC 내부 라우트 테이블 자동 업데이트 ──
    # Shared VPC의 EC2들이 Spoke VPC(prod, dev)와 통신하려면
    # Shared VPC의 라우트 테이블에 "10.10.0.0/16 → TGW" 경로가 있어야 합니다.
    # vpc_route_table_ids에 해당 라우트 테이블 ID를 넣으면 Terraform이 자동으로 경로를 추가합니다.
    #
    # [변경] Shared VPC의 프라이빗 서브넷 라우트 테이블 ID 목록
    # 확인: AWS 콘솔 → VPC → 라우트 테이블 → 해당 VPC의 테이블 ID 복사
    vpc_route_table_ids = ["rtb-0xxxxxxx1", "rtb-0xxxxxxx2"]

    # [변경] 위 라우트 테이블에 추가할 대상 CIDR 목록
    # 아래는 prod(10.10.0.0/16)와 dev(10.20.0.0/16)로 가는 트래픽을 TGW로 보내는 설정
    routes_to_tgw = ["10.10.0.0/16", "10.20.0.0/16"]
  }

  # ── Prod VPC ──
  prod = {
    # [변경] 운영 VPC ID
    vpc_id = "vpc-0xxxxxxxxxxxxxxx2"

    # [변경] 운영 VPC TGW 전용 서브넷 ID 목록
    subnet_ids = ["subnet-0yyyyyyy1", "subnet-0yyyyyyy2", "subnet-0yyyyyyy3"]

    route_table_key = "prod"

    # [변경] Prod VPC 프라이빗 서브넷의 라우트 테이블 ID 목록
    vpc_route_table_ids = ["rtb-0yyyyyyy1", "rtb-0yyyyyyy2"]

    # "0.0.0.0/0" → 인터넷을 포함한 모든 트래픽을 TGW로 보냄
    # (인터넷 트래픽은 TGW에서 Egress VPC로 다시 라우팅됨)
    routes_to_tgw = ["0.0.0.0/0"]
  }

  # ── Dev VPC ──
  dev = {
    # [변경] 개발 VPC ID
    vpc_id = "vpc-0xxxxxxxxxxxxxxx3"

    # [변경] 개발 VPC TGW 전용 서브넷 ID 목록
    subnet_ids = ["subnet-0zzzzzzz1", "subnet-0zzzzzzz2", "subnet-0zzzzzzz3"]

    route_table_key = "dev"

    # [변경] Dev VPC 프라이빗 서브넷의 라우트 테이블 ID 목록
    vpc_route_table_ids = ["rtb-0zzzzzzz1"]

    routes_to_tgw = ["0.0.0.0/0"]
  }
}


# ── 라우트 전파 (Route Propagation) ─────────────────────────────
# "어떤 VPC의 CIDR을 어떤 라우트 테이블에 자동으로 알릴 것인가" 를 정의합니다.
#
# 예시 읽는 법:
#   shared_from_prod:
#     attachment_key  = "prod"   → prod VPC의 CIDR(10.10.0.0/16)을
#     route_table_key = "shared" → shared 라우트 테이블에 전파
#   = "shared 라우트 테이블을 가진 VPC(공유 VPC)가 prod VPC를 향해 패킷을 보낼 수 있게 됨"
#
# [변경] 필요한 통신 경로만 허용하도록 추가/제거하세요.
# prod ↔ dev 전파는 의도적으로 없음 → 두 환경은 직접 통신 불가
tgw_route_table_propagations = {
  # Shared RT ← Prod, Dev CIDR 전파 (공유 서버 → Spoke VPC 통신용)
  shared_from_prod = { route_table_key = "shared", attachment_key = "prod" }
  shared_from_dev  = { route_table_key = "shared", attachment_key = "dev" }

  # Prod RT ← Shared CIDR 전파 (운영 서버 → 공유 서버 통신용)
  prod_from_shared = { route_table_key = "prod", attachment_key = "shared" }

  # Dev RT ← Shared CIDR 전파 (개발 서버 → 공유 서버 통신용)
  dev_from_shared = { route_table_key = "dev", attachment_key = "shared" }
}


# ── 정적 경로 (Static Routes) ────────────────────────────────────
# 전파로 자동 학습되지 않는 경로나 명시적 차단(블랙홀)을 설정합니다.
#
# [변경] 환경에 맞게 추가/제거하세요.
# 블랙홀(blackhole = true): 해당 CIDR로 가는 패킷을 TGW에서 버립니다.
#   - 전파 설정이 없어도 다른 경로로 우회할 수 있기 때문에
#     명시적 차단이 필요하면 반드시 블랙홀 경로를 추가해야 합니다.
tgw_static_routes = {
  # Prod에서 Dev로 가는 트래픽 차단 (운영-개발 격리)
  # [변경] dev_vpc_cidr를 실제 Dev VPC CIDR로 교체
  prod_block_dev = {
    route_table_key        = "prod"
    destination_cidr_block = "10.20.0.0/16" # [변경] Dev VPC CIDR
    blackhole              = true
  }

  # Dev에서 Prod로 가는 트래픽 차단
  # [변경] prod_vpc_cidr를 실제 Prod VPC CIDR로 교체
  dev_block_prod = {
    route_table_key        = "dev"
    destination_cidr_block = "10.10.0.0/16" # [변경] Prod VPC CIDR
    blackhole              = true
  }

  # [선택] Egress VPC를 통한 중앙 집중식 인터넷 출구 설정
  # Egress VPC(NAT GW 포함)가 있을 경우 아래 주석 해제
  # prod_default_to_egress = {
  #   route_table_key        = "prod"
  #   destination_cidr_block = "0.0.0.0/0"
  #   attachment_key         = "egress"  # Egress VPC 어태치먼트 키
  #   blackhole              = false
  # }
  # dev_default_to_egress = {
  #   route_table_key        = "dev"
  #   destination_cidr_block = "0.0.0.0/0"
  #   attachment_key         = "egress"
  #   blackhole              = false
  # }
}


# ── RAM 공유 - 멀티 어카운트 ─────────────────────────────────────
# 단일 AWS 계정이라면 false로 두세요.
# 여러 AWS 계정이 이 TGW를 공유해야 한다면 true로 변경하고
# ram_principals에 공유할 계정 ID를 입력하세요.
#
# 사전 조건: AWS Organizations에서 RAM 공유가 활성화되어 있어야 합니다.
#   aws organizations enable-aws-service-access --service-principal ram.amazonaws.com
enable_ram_sharing = false

# [변경 - RAM 공유 시] TGW를 공유할 AWS 계정 ID 또는 OU ARN 목록
# 계정 ID 예시: "123456789012"
# OU ARN 예시:  "arn:aws:organizations::123456789012:ou/o-xxxx/ou-xxxx-xxxxxxxx"
# ram_principals = ["123456789012", "234567890123"]

# 외부 Organization과 공유할 경우에만 true
# (같은 Organization 내 계정 공유라면 false)
# ram_allow_external_principals = false


# ── 공통 태그 ────────────────────────────────────────────────────
# [변경] 조직의 태깅 정책에 맞게 수정하세요.
# 이 태그는 TGW, 라우트 테이블, 어태치먼트 등 모든 리소스에 붙습니다.
# versions.tf의 default_tags (ManagedBy, Project, Environment)와 합산됩니다.
tags = {
  CostCenter = "networking"    # [변경] 비용 센터 코드
  Owner      = "platform-team" # [변경] 담당 팀 또는 담당자
  Terraform  = "true"
}
