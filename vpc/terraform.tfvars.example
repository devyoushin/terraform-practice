###############################################
# terraform.tfvars.example
# 이 파일을 참고하여 각 환경의 terraform.tfvars를 작성하세요.
# cp terraform.tfvars.example envs/dev/terraform.tfvars
###############################################

aws_region   = "ap-northeast-2"
project_name = "my-project"   # ← 프로젝트 이름 입력
owner        = "infra-team"   # ← 담당자/팀 이름 입력

# -----------------------------------------------
# 네트워크
# -----------------------------------------------
vpc_cidr = "10.10.0.0/16"   # ← 환경별 CIDR: dev=10.10, staging=10.20, prod=10.30

azs = ["ap-northeast-2a", "ap-northeast-2c"]   # prod는 3개 AZ 권장

public_subnet_cidrs  = ["10.10.101.0/24", "10.10.102.0/24"]
private_subnet_cidrs = ["10.10.1.0/24", "10.10.2.0/24"]

# -----------------------------------------------
# VPC Endpoint (선택 - 무료)
# -----------------------------------------------
enable_s3_endpoint       = false   # S3를 VPC 내부 경유로 접근 (비용 절감)
enable_dynamodb_endpoint = false   # DynamoDB VPC 내부 경유

# -----------------------------------------------
# Flow Logs (선택 - CloudWatch 비용 발생)
# -----------------------------------------------
enable_flow_logs         = false   # prod는 true 권장
flow_logs_retention_days = 30
