# Terraform 상태 파일 (로컬 백엔드 사용 시 생성)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform 플랜 파일 (민감 정보 포함 가능)
*.tfplan
*.plan

# 환경 변수 파일 (민감 정보 포함)
*.tfvars
!terraform.tfvars.example

# Terraform 내부 디렉토리
.terraform/
.terraform.lock.hcl

# 크래시 로그
crash.log
crash.*.log

# Terraform 오버라이드 파일 (로컬 개발용)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI 설정 파일 (민감 정보 포함 가능)
.terraformrc
terraform.rc

# macOS 시스템 파일
.DS_Store
.AppleDouble
.LSOverride

# IDE 설정
.idea/
.vscode/
*.swp
*.swo
*~

# 로그 파일
*.log

# 임시 파일
*.tmp
*.bak
