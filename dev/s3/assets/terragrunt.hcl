### =============================================================================
### dev/s3/assets/terragrunt.hcl
### DEV 환경 S3 버킷 — 정적 에셋 (assets)
###
### 역할: 이미지, CSS, JS 등 정적 파일을 저장하는 S3 버킷
###       CloudFront 오리진으로 사용됨
### DEV 특징:
###   - force_destroy = true: 비어있지 않아도 버킷 삭제 가능 (개발 편의)
###   - enable_versioning = false: 버전 관리 비활성화 (비용 절약)
###   - enable_lifecycle = false: 수명주기 정책 없음 (dev는 데이터 보존 불필요)
###   - KMS 암호화: 미적용 (SSE-S3 기본 암호화만 사용)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../s3/modules/s3"
}

inputs = {
  # ---------------------------------------------------------------
  # 버킷 식별자
  # 최종 버킷 이름: {project_name}-dev-assets
  # ---------------------------------------------------------------
  bucket_suffix = "assets"

  # ---------------------------------------------------------------
  # 버전 관리
  # dev: false (비용 절약, 개발 중 잦은 파일 교체)
  # prod: true (실수 삭제 복구, 객체 이력 관리)
  # ---------------------------------------------------------------
  enable_versioning = false

  # ---------------------------------------------------------------
  # 버킷 강제 삭제
  # dev: true (객체가 남아있어도 terraform destroy 시 삭제)
  # prod: false (실수 삭제 방지)
  # ---------------------------------------------------------------
  force_destroy = true

  # ---------------------------------------------------------------
  # 수명주기 정책
  # dev: false (개발 데이터는 보존 기간 불필요)
  # prod: true (오래된 객체 자동 삭제 또는 Glacier 이전)
  # ---------------------------------------------------------------
  enable_lifecycle = false
}
