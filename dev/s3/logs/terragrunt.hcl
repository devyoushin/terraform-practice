### =============================================================================
### dev/s3/logs/terragrunt.hcl
### DEV 환경 S3 버킷 — 로그 저장 (logs)
###
### 역할: ALB 액세스 로그, CloudTrail, VPC Flow Logs 등을 저장하는 S3 버킷
###       각 AWS 서비스가 직접 이 버킷에 로그를 기록
### DEV 특징:
###   - force_destroy = true: 로그 데이터가 남아있어도 삭제 가능
###   - enable_versioning = false: 로그 파일은 버전 관리 불필요
###   - enable_lifecycle = true: 오래된 로그 자동 삭제 (비용 관리)
###     → dev는 짧은 보존 기간 설정 (예: 30일)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../s3/modules/s3"
}

inputs = {
  # ---------------------------------------------------------------
  # 버킷 식별자
  # 최종 버킷 이름: {project_name}-dev-logs
  # ---------------------------------------------------------------
  bucket_suffix = "logs"

  # ---------------------------------------------------------------
  # 버전 관리
  # 로그 버킷은 버전 관리 불필요
  # ---------------------------------------------------------------
  enable_versioning = false

  # ---------------------------------------------------------------
  # 강제 삭제
  # dev: 로그가 축적되어도 terraform destroy 가능하도록 true
  # ---------------------------------------------------------------
  force_destroy = true

  # ---------------------------------------------------------------
  # 수명주기 정책
  # dev: true — 오래된 로그 자동 정리 (비용 제어)
  # prod: true — 보안 감사를 위해 더 긴 보존 기간 (90일+)
  # ---------------------------------------------------------------
  enable_lifecycle = true

  # ---------------------------------------------------------------
  # 수명주기 보존 기간 (일)
  # dev: 30일이면 충분
  # prod: 90~365일 (컴플라이언스 요건에 따라 결정)
  # ---------------------------------------------------------------
  lifecycle_expiration_days = 30
}
