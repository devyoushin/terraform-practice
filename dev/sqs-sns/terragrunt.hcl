### =============================================================================
### dev/sqs-sns/terragrunt.hcl
### DEV 환경 SQS + SNS (메시지 큐 및 알림)
###
### 역할: 서비스 간 비동기 메시지 처리 및 이벤트 알림
###       SQS: 메시지 큐 (처리 실패 시 DLQ로 이동)
###       SNS: 팬아웃 알림 (여러 SQS/이메일/Lambda 동시 전달)
### DEV 특징:
###   - enable_kms = false: AWS 관리형 암호화 (SQS 기본 SSE)
###   - enable_alarms = false: CloudWatch 알람 비활성화
###   - visibility_timeout_seconds = 30: 메시지 처리 제한 시간 30초
###   - message_retention_seconds = 345600: 4일 보존
###   - max_receive_count = 3: 3번 실패 후 DLQ로 이동
### 의존성: 없음
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../sqs-sns/modules/sqs-sns"
}

inputs = {
  # ---------------------------------------------------------------
  # 큐 이름
  # 최종 이름: terraform-practice-dev-queue
  # DLQ 이름: terraform-practice-dev-queue-dlq (모듈에서 자동 생성)
  # ---------------------------------------------------------------
  queue_name = "terraform-practice-dev-queue"

  # ---------------------------------------------------------------
  # Visibility Timeout
  # 메시지를 가져간 컨슈머가 삭제하지 않으면 이 시간 후 다시 큐에 복귀
  # Lambda: Lambda 타임아웃의 6배 이상으로 설정 권장
  # dev: 30초 (기본값)
  # ---------------------------------------------------------------
  visibility_timeout_seconds = 30

  # ---------------------------------------------------------------
  # 메시지 보존 기간
  # dev: 345600초 = 4일
  # prod: 1209600초 = 14일 (최대값)
  # ---------------------------------------------------------------
  message_retention_seconds = 345600

  # ---------------------------------------------------------------
  # Dead Letter Queue (DLQ) 설정
  # max_receive_count: N번 처리 실패 시 DLQ로 이동
  # dev: 3번 (빠른 실패 확인)
  # prod: 5번 (일시적 오류로 인한 DLQ 이동 방지)
  # ---------------------------------------------------------------
  max_receive_count = 3

  # ---------------------------------------------------------------
  # KMS 암호화
  # dev: false (AWS 관리형 SSE 사용, 추가 비용 없음)
  # prod: true (CMK 사용으로 키 접근 감사 및 세밀한 권한 제어)
  # ---------------------------------------------------------------
  enable_kms = false

  # ---------------------------------------------------------------
  # CloudWatch 알람
  # dev: false (큐 깊이 알람 불필요)
  # prod: true (DLQ 메시지 발생, 큐 깊이 임계값 초과 시 알람)
  # ---------------------------------------------------------------
  enable_alarms = false

  # ---------------------------------------------------------------
  # SNS 토픽 설정
  # ---------------------------------------------------------------
  topic_name = "terraform-practice-dev-topic"

  # FIFO 큐/토픽 설정
  # dev: false (표준 큐, 순서 보장 불필요)
  # prod: 순서 보장 필요 시 true (결제, 재고 처리 등)
  fifo_queue = false
}
