### =============================================================================
### dev/guardduty/terragrunt.hcl
### DEV 환경 GuardDuty (위협 탐지)
###
### 역할: AWS 계정 내 비정상 활동, 악성 IP 접근, 크리덴셜 도용 등을 자동 탐지
###       CloudTrail, VPC Flow Logs, DNS 로그를 분석하여 위협 탐지
### DEV 특징:
###   - finding_frequency = "SIX_HOURS": 6시간마다 findings 업데이트
###     prod: "FIFTEEN_MINUTES" (빠른 위협 탐지)
###   - enable_s3_logs = true: S3 데이터 이벤트 모니터링
###   - enable_malware_protection = false: 멀웨어 스캔 비활성화 (비용 절약)
###   - finding_min_severity = "MEDIUM": 중간 이상 심각도만 알림
### 의존성: 없음
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../guardduty/modules/guardduty"
}

inputs = {
  # ---------------------------------------------------------------
  # Findings 업데이트 빈도
  # FIFTEEN_MINUTES: 고빈도 (prod 권장)
  # ONE_HOUR: 중간
  # SIX_HOURS: 저빈도 (dev: 비용 절약, 빠른 응답 불필요)
  # ---------------------------------------------------------------
  finding_frequency = "SIX_HOURS"

  # ---------------------------------------------------------------
  # S3 로그 모니터링
  # dev: true (S3 버킷 무단 접근 시도 탐지)
  # S3 데이터 이벤트 로그를 분석하여 비정상 접근 감지
  # ---------------------------------------------------------------
  enable_s3_logs = true

  # ---------------------------------------------------------------
  # EKS 모니터링
  # EKS 클러스터 내 비정상 API 호출 탐지
  # dev: true (EKS 배포 환경이므로 활성화)
  # ---------------------------------------------------------------
  enable_eks_protection = true

  # ---------------------------------------------------------------
  # 멀웨어 보호 (EC2, ECS 인스턴스 스캔)
  # dev: false (EC2 EBS 볼륨 스냅샷 스캔 비용 발생)
  # prod: true (실제 워크로드 보호)
  # ---------------------------------------------------------------
  enable_malware_protection = false

  # ---------------------------------------------------------------
  # Findings 심각도 필터링
  # LOW: 낮은 위협 (정보성)
  # MEDIUM: 중간 위협 (주의 필요)
  # HIGH: 높은 위협 (즉각 대응 필요)
  # dev: MEDIUM 이상만 알림 (LOW는 개발 중 노이즈 가능성 높음)
  # prod: LOW 이상 모두 알림
  # ---------------------------------------------------------------
  finding_min_severity = "MEDIUM"

  # ---------------------------------------------------------------
  # SNS 알림 설정
  # dev: false (이메일 알람 불필요)
  # prod: true (보안팀 이메일/Slack 연동)
  # ---------------------------------------------------------------
  enable_sns_notification = false

  # ---------------------------------------------------------------
  # GuardDuty Findings 내보내기
  # S3 버킷에 Findings 데이터를 저장하여 장기 분석 가능
  # dev: false (비용 절약)
  # prod: true (SIEM 연동, 감사 보관)
  # ---------------------------------------------------------------
  enable_findings_export = false
}
