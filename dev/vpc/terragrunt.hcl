### =============================================================================
### dev/vpc/terragrunt.hcl
### DEV 환경 VPC (Virtual Private Cloud)
###
### 역할: 모든 AWS 리소스의 네트워크 기반
### DEV 특징:
###   - 단일 NAT Gateway (비용 절약 — prod는 AZ별 NAT)
###   - Flow Logs 비활성화 (로그 비용 절약)
###   - VPC CIDR: 10.10.0.0/16 (prod: 10.0.0.0/16 와 분리)
###   - 2개 AZ 사용 (prod: 3개 AZ)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../vpc/modules/vpc"
}

inputs = {
  # ---------------------------------------------------------------
  # 네트워크 설계
  # CIDR 분할:
  #   퍼블릭:  10.10.1.0/24, 10.10.2.0/24
  #   프라이빗: 10.10.11.0/24, 10.10.12.0/24
  # ---------------------------------------------------------------
  vpc_cidr = "10.10.0.0/16"

  azs = [
    "ap-northeast-2a",
    "ap-northeast-2c",
  ]

  public_subnet_cidrs = [
    "10.10.1.0/24",
    "10.10.2.0/24",
  ]

  private_subnet_cidrs = [
    "10.10.11.0/24",
    "10.10.12.0/24",
  ]

  # ---------------------------------------------------------------
  # NAT Gateway
  # dev: single_nat_gateway = true → 1개만 생성 (비용 절약)
  # prod: single_nat_gateway = false → AZ별 생성 (고가용성)
  # ---------------------------------------------------------------
  enable_nat_gateway = true
  single_nat_gateway = true

  # ---------------------------------------------------------------
  # VPC Endpoint (무료 Gateway 엔드포인트)
  # S3, DynamoDB 는 게이트웨이 타입으로 추가 비용 없음
  # ---------------------------------------------------------------
  enable_s3_endpoint       = true
  enable_dynamodb_endpoint = true

  # ---------------------------------------------------------------
  # VPC Flow Logs
  # dev: 비활성화 (CloudWatch 로그 비용 절약)
  # prod: 활성화 필수 (보안 감사 및 이상 트래픽 탐지)
  # ---------------------------------------------------------------
  enable_flow_logs = false
}
