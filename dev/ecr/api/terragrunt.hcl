### =============================================================================
### dev/ecr/api/terragrunt.hcl
### DEV 환경 ECR — API 서버 컨테이너 이미지 저장소 (api)
###
### 역할: 백엔드 API 서버 Docker 이미지를 저장하는 ECR 리포지토리
###       app 리포지토리와 분리하여 이미지 접근 권한을 독립적으로 관리
### DEV 특징:
###   - app 리포지토리와 동일한 dev 설정 적용
###   - image_tag_mutability = "MUTABLE"
###   - force_delete = true
###   - scan_on_push = false
###   - lifecycle_policy_count = 10
### 의존성: 없음
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../ecr/modules/ecr"
}

inputs = {
  # ---------------------------------------------------------------
  # 리포지토리 이름
  # 최종 이름: terraform-practice-api
  # 이미지 URI: {account}.dkr.ecr.ap-northeast-2.amazonaws.com/terraform-practice-api
  # ---------------------------------------------------------------
  repo_name = "terraform-practice-api"

  # ---------------------------------------------------------------
  # 이미지 태그 변경 가능 여부
  # dev: MUTABLE (latest 태그 재사용으로 개발 속도 향상)
  # prod: IMMUTABLE (태그별 이미지 불변성 보장)
  # ---------------------------------------------------------------
  image_tag_mutability = "MUTABLE"

  # ---------------------------------------------------------------
  # 강제 삭제
  # dev: true (개발 중 자유로운 리포지토리 삭제)
  # ---------------------------------------------------------------
  force_delete = true

  # ---------------------------------------------------------------
  # 이미지 취약점 스캔
  # dev: false (비용 절약)
  # prod: true (CVE 취약점 자동 탐지)
  # ---------------------------------------------------------------
  scan_on_push = false

  # ---------------------------------------------------------------
  # 라이프사이클 정책
  # dev: 최근 10개 이미지 보존 (디스크 비용 절약)
  # prod: 30개 이상 또는 보존 정책에 따라 설정
  # ---------------------------------------------------------------
  lifecycle_policy_count = 10
}
