### =============================================================================
### dev/ecr/app/terragrunt.hcl
### DEV 환경 ECR — 앱 컨테이너 이미지 저장소 (app)
###
### 역할: 프론트엔드/메인 애플리케이션 Docker 이미지를 저장하는 ECR 리포지토리
###       CodePipeline에서 빌드한 이미지를 push, ECS/EKS에서 pull
### DEV 특징:
###   - image_tag_mutability = "MUTABLE": 같은 태그로 이미지 덮어쓰기 허용
###     (dev: latest 태그 재사용, prod: IMMUTABLE로 변경 이력 보장)
###   - force_delete = true: 이미지가 있어도 리포지토리 삭제 가능
###   - scan_on_push = false: 이미지 취약점 스캔 비활성화 (비용 절약)
###   - lifecycle_policy_count = 10: 최근 10개 이미지만 보존
### 의존성: 없음
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../ecr/modules/ecr"
}

inputs = {
  # ---------------------------------------------------------------
  # 리포지토리 이름
  # 최종 이름: terraform-practice-app
  # 이미지 URI: {account}.dkr.ecr.ap-northeast-2.amazonaws.com/terraform-practice-app
  # ---------------------------------------------------------------
  repo_name = "terraform-practice-app"

  # ---------------------------------------------------------------
  # 이미지 태그 변경 가능 여부
  # MUTABLE: 같은 태그로 이미지 교체 가능 (dev: latest 태그 재사용)
  # IMMUTABLE: 한 번 push한 태그는 불변 (prod: 배포 이력 추적)
  # ---------------------------------------------------------------
  image_tag_mutability = "MUTABLE"

  # ---------------------------------------------------------------
  # 강제 삭제
  # dev: true (이미지가 있어도 terraform destroy 시 삭제)
  # prod: false (실수 삭제로 인한 이미지 손실 방지)
  # ---------------------------------------------------------------
  force_delete = true

  # ---------------------------------------------------------------
  # 이미지 취약점 스캔
  # dev: false (비용 절약, 로컬 빌드 이미지 위주)
  # prod: true (ECR Enhanced Scanning 또는 Basic Scanning 활성화)
  # ---------------------------------------------------------------
  scan_on_push = false

  # ---------------------------------------------------------------
  # 라이프사이클 정책 — 오래된 이미지 자동 정리
  # dev: 최근 10개 이미지만 보존
  # prod: 최근 30개 또는 날짜 기반 보존
  # ---------------------------------------------------------------
  lifecycle_policy_count = 10
}
