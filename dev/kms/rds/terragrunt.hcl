### =============================================================================
### dev/kms/rds/terragrunt.hcl
### DEV 환경 KMS 키 — RDS 암호화용
###
### 역할: RDS 인스턴스 저장 데이터 암호화에 사용할 KMS CMK 생성
### DEV 특징:
###   - deletion_window_in_days = 7 (최솟값, prod는 30일)
###   - 개발 중 자유로운 키 삭제를 위해 대기 기간 최소화
###   - 실제 dev RDS에서는 KMS 암호화가 선택적 (비용 고려)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../kms/modules/kms"
}

inputs = {
  # ---------------------------------------------------------------
  # 키 식별자
  # 생성되는 별칭: alias/{project_name}-dev-rds
  # ---------------------------------------------------------------
  key_suffix = "rds"

  # ---------------------------------------------------------------
  # 키 삭제 대기 기간
  # dev: 7일 (최솟값) — 개발 환경에서 빠른 정리를 위해
  # prod: 30일 — 실수로 인한 삭제 복구 기간 확보
  # ---------------------------------------------------------------
  deletion_window_in_days = 7

  # ---------------------------------------------------------------
  # 키 교체 (Key Rotation)
  # dev: 비활성화 (선택적)
  # prod: 활성화 필수 (보안 컴플라이언스)
  # ---------------------------------------------------------------
  enable_key_rotation = false
}
