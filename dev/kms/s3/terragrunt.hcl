### =============================================================================
### dev/kms/s3/terragrunt.hcl
### DEV 환경 KMS 키 — S3 버킷 암호화용
###
### 역할: S3 버킷의 서버사이드 암호화(SSE-KMS)에 사용할 CMK 생성
### DEV 특징:
###   - deletion_window_in_days = 7 (최솟값)
###   - dev S3 버킷은 SSE-S3(AWS 관리형)로도 충분하나
###     KMS를 별도 구성하여 prod와 동일한 구조 유지
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../kms/modules/kms"
}

inputs = {
  # ---------------------------------------------------------------
  # 키 식별자
  # 생성되는 별칭: alias/{project_name}-dev-s3
  # ---------------------------------------------------------------
  key_suffix = "s3"

  # ---------------------------------------------------------------
  # 키 삭제 대기 기간
  # dev: 7일 (최솟값) — 신속한 환경 정리 가능
  # prod: 30일 — 데이터 보호를 위한 충분한 복구 기간
  # ---------------------------------------------------------------
  deletion_window_in_days = 7

  # ---------------------------------------------------------------
  # 키 교체
  # dev: 비활성화 (테스트 목적)
  # prod: 활성화 (연간 자동 교체로 보안 강화)
  # ---------------------------------------------------------------
  enable_key_rotation = false
}
