### =============================================================================
### dev/kms/eks/terragrunt.hcl
### DEV 환경 KMS 키 — EKS Secrets 암호화용
###
### 역할: EKS 클러스터 내 Kubernetes Secrets 봉투 암호화(Envelope Encryption)에
###       사용할 CMK 생성
### DEV 특징:
###   - deletion_window_in_days = 7 (최솟값)
###   - EKS 클러스터 삭제 전 반드시 이 키를 먼저 해제해야 함
###   - 키 삭제 시 클러스터 Secrets 영구 손실 주의
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../kms/modules/kms"
}

inputs = {
  # ---------------------------------------------------------------
  # 키 식별자
  # 생성되는 별칭: alias/{project_name}-dev-eks
  # EKS 클러스터 생성 시 이 키의 ARN을 참조
  # ---------------------------------------------------------------
  key_suffix = "eks"

  # ---------------------------------------------------------------
  # 키 삭제 대기 기간
  # dev: 7일 — 개발 클러스터 정리 시 빠른 키 삭제
  # prod: 30일 — 실수로 인한 Secrets 암호화 키 손실 방지
  # ---------------------------------------------------------------
  deletion_window_in_days = 7

  # ---------------------------------------------------------------
  # 키 교체
  # dev: 비활성화
  # prod: 활성화 (Kubernetes Secrets 보안 강화)
  # ---------------------------------------------------------------
  enable_key_rotation = false
}
