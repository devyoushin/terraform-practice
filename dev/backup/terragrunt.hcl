### =============================================================================
### dev/backup/terragrunt.hcl
### DEV 환경 AWS Backup
###
### 역할: RDS, DynamoDB, EFS 등 stateful 리소스의 자동 백업 정책 설정
###       규정 준수 및 데이터 복구를 위한 중앙 집중식 백업 관리
### DEV 특징:
###   - backup_retention_days = 7: 7일 보존 (최소값)
###   - cold_storage_after_days = 0: Glacier 이전 없음 (비용 절약)
###   - kms_key_arn = null: AWS 관리형 키 사용
###   - 백업 빈도: 1일 1회 (새벽 2시)
### 의존성: 없음
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../backup/modules/backup"
}

inputs = {
  # ---------------------------------------------------------------
  # 백업 플랜 이름
  # ---------------------------------------------------------------
  backup_plan_name = "terraform-practice-dev-backup"

  # ---------------------------------------------------------------
  # 백업 보존 기간
  # dev: 7일 (최소값, 비용 절약)
  # prod: 30~90일 (데이터 복구 요건에 따라 설정)
  # ---------------------------------------------------------------
  backup_retention_days = 7

  # ---------------------------------------------------------------
  # Glacier 이전 (Cold Storage)
  # dev: 0 = Glacier 이전 없음
  # prod: 30일 후 Glacier로 이전 (장기 보관 비용 절약)
  # 주의: cold_storage_after_days >= backup_retention_days 이면 오류
  # ---------------------------------------------------------------
  cold_storage_after_days = 0

  # ---------------------------------------------------------------
  # 백업 일정 (Cron 표현식)
  # 매일 새벽 2시 KST = UTC 17:00 (전날)
  # ---------------------------------------------------------------
  backup_schedule = "cron(0 17 * * ? *)"

  # ---------------------------------------------------------------
  # 백업 대상 리소스 태그 기반 선택
  # Backup = "true" 태그가 있는 리소스를 자동으로 백업 대상에 포함
  # 각 모듈의 common_tags에 Backup = "true" 추가 시 자동 적용
  # ---------------------------------------------------------------
  backup_tag_key   = "Backup"
  backup_tag_value = "true"

  # ---------------------------------------------------------------
  # KMS 암호화
  # dev: null = AWS 관리형 백업 키 사용
  # prod: KMS CMK ARN 지정 (kms 모듈 출력값 활용)
  # ---------------------------------------------------------------
  kms_key_arn = null

  # ---------------------------------------------------------------
  # 백업 완료 시간 창 (시간 단위)
  # 백업이 이 시간 내에 완료되지 않으면 취소
  # ---------------------------------------------------------------
  completion_window_minutes = 120
  start_window_minutes      = 60
}
