###############################################
# terraform.tfvars.example
# 이 파일을 복사 후 실제 값을 입력하세요
# cp terraform.tfvars.example envs/dev/terraform.tfvars
###############################################

aws_region   = "ap-northeast-2"
project_name = "my-project"   # ← 프로젝트 이름 입력
owner        = "dev-team"     # ← 담당자/팀 이름 입력

# -----------------------------------------------
# 알림 설정
# -----------------------------------------------
# 빈 값("")이면 이메일 구독 생략 (SNS 토픽은 생성됨)
alert_email = ""  # ← 알림 수신 이메일 입력 (예: security@company.com)

# -----------------------------------------------
# prod 전용 설정
# -----------------------------------------------
# EKS 클러스터 위협 탐지 (EKS 사용 환경에서만 true)
# enable_kubernetes_audit_logs = false

# 내부 보안 스캐너, 감사 도구 등 알려진 IP 제외
# filter_trusted_ips = [
#   "10.0.1.100",   # 내부 보안 스캐너
#   "10.0.2.100",   # 감사 도구
# ]
