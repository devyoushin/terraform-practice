### =============================================================================
### prod/dynamodb/tfstate-lock/terragrunt.hcl
### PROD 환경 DynamoDB — Terraform 상태 잠금 테이블
###
### 역할: Terraform 원격 상태(S3)의 동시 수정 방지를 위한 분산 잠금
###   - 여러 팀원이 동시에 terraform apply 실행 시 충돌 방지
###   - "LockID" 파티션 키가 Terraform 규격 (변경 금지!)
###
### 참고: 이 테이블은 bootstrap/ 에서도 생성 가능합니다.
###       bootstrap/ 을 사용하지 않는 경우 이 모듈로 생성하세요.
###
### PROD 특징:
###   - enable_pitr = true          (특정 시점 복구)
###   - deletion_protection = true  (실수 삭제 방지)
###   - 의존성 없음 (가장 먼저 배포 가능)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ 이 테이블이 없으면 Terraform 상태 잠금이 동작하지 않음!
### ⚠️ 테이블명이 루트 terragrunt.hcl 의 dynamodb_table 과 일치해야 함
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../dynamodb/modules/dynamodb"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 테이블 식별자
  # ⚠️ 중요: 이 이름은 루트 terragrunt.hcl 의 dynamodb_table 값과
  #          반드시 일치해야 합니다!
  #
  # 루트 terragrunt.hcl:
  #   dynamodb_table = "${local.project_name}-tfstate-lock"
  #   → "terraform-practice-tfstate-lock"
  # ---------------------------------------------------------------
  table_suffix = "tfstate-lock"

  # ---------------------------------------------------------------
  # 기본 키 설계
  # ⚠️ Terraform 규격: 파티션 키는 반드시 "LockID" (String 타입)
  #    이 값을 변경하면 Terraform 상태 잠금이 동작하지 않습니다!
  # ---------------------------------------------------------------
  hash_key      = "LockID"
  hash_key_type = "S"  # String — 변경 금지!

  # ---------------------------------------------------------------
  # 요금 모드
  # PAY_PER_REQUEST: 잠금 테이블은 간헐적 접근이므로 온디맨드가 경제적
  # ---------------------------------------------------------------
  billing_mode = "PAY_PER_REQUEST"

  # ---------------------------------------------------------------
  # TTL 비활성화
  # 잠금 레코드는 Terraform이 자동 삭제 — TTL 불필요
  # ---------------------------------------------------------------
  enable_ttl = false

  # ---------------------------------------------------------------
  # 특정 시점 복구 (PITR)
  # prod: true — 잠금 테이블도 복구 가능하도록 보호
  # ---------------------------------------------------------------
  enable_pitr = true

  # ---------------------------------------------------------------
  # 삭제 방지
  # prod: true — 잠금 테이블 삭제 시 동시 배포 충돌 위험
  # ---------------------------------------------------------------
  deletion_protection = true
}
