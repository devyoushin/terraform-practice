### =============================================================================
### prod/dynamodb/sessions/terragrunt.hcl
### PROD 환경 DynamoDB — 세션 스토어
###
### 역할: 사용자 세션 데이터 저장 (분산 세션 관리)
###   - 서버리스 완전 관리형 — 인프라 관리 불필요
###   - Auto Scaling으로 트래픽에 따라 용량 자동 조정
###
### PROD 특징:
###   - enable_pitr = true           (특정 시점 복구 — PITR 활성화)
###   - deletion_protection = true   (실수 삭제 방지)
###   - 온디맨드(PAY_PER_REQUEST) 모드 — 예측 불가 트래픽에 적합
###
### 의존성:
###   - kms/s3 → DynamoDB 테이블 암호화 KMS 키
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ PITR 활성화 시 추가 비용 발생 (데이터 크기에 비례)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

dependency "kms_s3" {
  config_path = "../../kms/s3"
  mock_outputs_allowed_terraform_commands = ["validate", "plan"]
  mock_outputs = {
    key_id  = "00000000-0000-0000-0000-000000000000"
    key_arn = "arn:aws:kms:ap-northeast-2:123456789012:key/00000000-0000-0000-0000-000000000000"
  }
}

terraform {
  source = "../../../dynamodb/modules/dynamodb"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 테이블 식별자
  # 최종 테이블명: {project_name}-prod-sessions
  # ---------------------------------------------------------------
  table_suffix = "sessions"

  # ---------------------------------------------------------------
  # 기본 키 설계
  # 파티션 키: session_id (UUID) — 균등 분산을 위한 고카디널리티 키
  # ---------------------------------------------------------------
  hash_key  = "session_id"
  hash_key_type = "S"  # String

  # ---------------------------------------------------------------
  # 요금 모드
  # prod: PAY_PER_REQUEST — 세션은 트래픽 변동이 크므로 온디맨드 적합
  # ---------------------------------------------------------------
  billing_mode = "PAY_PER_REQUEST"

  # ---------------------------------------------------------------
  # TTL (Time To Live)
  # 만료된 세션 자동 삭제 — expires_at 속성 기준
  # ---------------------------------------------------------------
  enable_ttl  = true
  ttl_attribute = "expires_at"

  # ---------------------------------------------------------------
  # 특정 시점 복구 (PITR)
  # prod: true — 최대 35일 전 임의 시점으로 복구 가능
  # dev:  false — 비용 절약
  #
  # 사용 사례: 잘못된 데이터 삽입 시 특정 시점으로 롤백
  # 비용: 저장된 데이터 GB당 약 $0.20/월
  # ---------------------------------------------------------------
  enable_pitr = true

  # ---------------------------------------------------------------
  # 삭제 방지
  # prod: true — 세션 데이터 실수 삭제 방지
  # ⚠️ 비활성화하려면 콘솔에서 직접 설정 변경 필요
  # ---------------------------------------------------------------
  deletion_protection = true

  # ---------------------------------------------------------------
  # KMS 암호화
  # prod: CMK 사용 (감사 로그 및 세밀한 접근 제어)
  # ---------------------------------------------------------------
  kms_key_arn = dependency.kms_s3.outputs.key_arn

  # ---------------------------------------------------------------
  # 글로벌 보조 인덱스 (GSI) — 선택적
  # 사용자 ID로 해당 사용자의 모든 세션 조회 시 필요
  # ---------------------------------------------------------------
  # global_secondary_indexes = [
  #   {
  #     name               = "user_id-index"
  #     hash_key           = "user_id"
  #     projection_type    = "ALL"
  #   }
  # ]
}
