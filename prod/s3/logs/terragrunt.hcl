### =============================================================================
### prod/s3/logs/terragrunt.hcl
### PROD 환경 S3 버킷 — 로그 저장 (logs)
###
### 역할: 다양한 AWS 서비스의 액세스 로그 중앙 저장
###   - ALB 액세스 로그
###   - CloudFront 액세스 로그
###   - VPC Flow Logs (선택적)
###   - CodePipeline 아티팩트 저장
###
### PROD 특징:
###   - enable_versioning = false  (로그는 버전 관리 불필요)
###   - force_destroy = false      (운영 로그 보호)
###   - enable_lifecycle = true    (오래된 로그 자동 삭제/아카이브)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ 이 버킷은 ALB, CloudFront, CodePipeline이 의존 — 먼저 배포 필요
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../s3/modules/s3"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 버킷 식별자
  # 최종 버킷명: {project_name}-prod-logs-{account_id}
  # ALB, CloudFront, CodePipeline 등에서 이 버킷 이름을 참조
  # ---------------------------------------------------------------
  bucket_suffix = "logs"

  # ---------------------------------------------------------------
  # 버전 관리
  # logs: false — 로그 파일은 버전 관리 불필요 (스토리지 비용 최적화)
  # ---------------------------------------------------------------
  enable_versioning = false

  # ---------------------------------------------------------------
  # 강제 삭제 방지
  # prod: false — 운영 로그는 보안/컴플라이언스 목적으로 보호
  # ---------------------------------------------------------------
  force_destroy = false

  # ---------------------------------------------------------------
  # 수명 주기 정책 (Lifecycle)
  # logs: true — 오래된 로그 자동 정리로 스토리지 비용 최적화
  #
  # 권장 수명 주기 설정 (모듈 변수로 조정):
  #   - 생성 후 90일: Standard → Standard-IA (저빈도 액세스)
  #   - 생성 후 365일: Standard-IA → Glacier (아카이브)
  #   - 생성 후 2년: 자동 삭제 (컴플라이언스 요건에 따라 조정)
  # ---------------------------------------------------------------
  enable_lifecycle = true

  # 로그 보존 기간 (일) — 컴플라이언스 요건에 맞게 조정
  log_retention_days = 365
}
