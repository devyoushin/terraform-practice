### =============================================================================
### prod/s3/backup/terragrunt.hcl
### PROD 환경 S3 버킷 — 백업 저장 (backup)
###
### 역할: AWS Backup 서비스의 백업 데이터 저장 (prod 전용 버킷)
###   - RDS 스냅샷 export
###   - EBS 스냅샷 아카이브
###   - 애플리케이션 데이터 백업
###
### PROD 특징 (dev에는 없는 prod 전용 버킷):
###   - enable_versioning = true   (백업 파일의 버전 관리)
###   - force_destroy = false      (백업 데이터 강력 보호)
###   - enable_lifecycle = true    (비용 최적화 수명 주기 정책)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ 이 버킷은 재해 복구(DR)의 핵심 — 절대 임의 삭제 금지!
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../s3/modules/s3"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 버킷 식별자
  # 최종 버킷명: {project_name}-prod-backup-{account_id}
  # AWS Backup 서비스 설정에서 이 버킷 이름을 참조
  # ---------------------------------------------------------------
  bucket_suffix = "backup"

  # ---------------------------------------------------------------
  # 버전 관리
  # backup: true — 백업 파일 덮어쓰기 방지 및 이전 백업 보존
  # 특정 시점의 백업 파일로 롤백 가능
  # ---------------------------------------------------------------
  enable_versioning = true

  # ---------------------------------------------------------------
  # 강제 삭제 방지
  # prod: false — 백업 데이터는 재해 복구의 마지막 보루
  # ⚠️ 절대로 force_destroy = true 로 변경하지 마세요!
  # ---------------------------------------------------------------
  force_destroy = false

  # ---------------------------------------------------------------
  # 수명 주기 정책 (Lifecycle)
  # backup: true — 스토리지 비용 최적화를 위한 자동 티어링
  #
  # 권장 수명 주기 설정:
  #   - 생성 후 30일:  Standard → Standard-IA
  #   - 생성 후 90일:  Standard-IA → Glacier
  #   - 생성 후 730일: Glacier → 삭제 (2년 보존 후)
  #   * 법적/컴플라이언스 요건에 따라 보존 기간 조정 필요
  # ---------------------------------------------------------------
  enable_lifecycle = true

  # 백업 보존 기간 (일)
  backup_retention_days = 730
}
