### =============================================================================
### prod/s3/assets/terragrunt.hcl
### PROD 환경 S3 버킷 — 정적 자산 (assets)
###
### 역할: 웹 애플리케이션 정적 파일(이미지, CSS, JS 등) 저장
###       CloudFront와 연동하여 CDN 배포
###
### PROD 특징:
###   - enable_versioning = true  (객체 버전 관리 — 실수 삭제 복구)
###   - force_destroy = false     (버킷 내 객체 있을 경우 삭제 차단)
###   - enable_lifecycle = false  (자산 파일은 장기 보존 필요)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ force_destroy = false — 버킷 삭제 전 모든 객체 수동 삭제 필요
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../s3/modules/s3"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 버킷 식별자
  # 최종 버킷명: {project_name}-prod-assets-{account_id}
  # (S3 버킷명은 전역 고유해야 하므로 account_id 접미사 권장)
  # ---------------------------------------------------------------
  bucket_suffix = "assets"

  # ---------------------------------------------------------------
  # 버전 관리 (Versioning)
  # prod: true — 객체 덮어쓰기/삭제 시 이전 버전 복구 가능
  # dev:  선택적 — 스토리지 비용 절약 위해 비활성화 가능
  #
  # 장점: 실수로 덮어쓴 이미지/파일 복구, 변경 이력 추적
  # ---------------------------------------------------------------
  enable_versioning = true

  # ---------------------------------------------------------------
  # 강제 삭제 방지
  # prod: false — 버킷 내 객체가 있으면 Terraform이 삭제 차단
  # dev:  true  — 개발 환경 정리 시 객체 포함 버킷 삭제 허용
  #
  # ⚠️ prod에서 이 버킷을 삭제하려면:
  #    1. 모든 버전 포함 객체 수동 삭제
  #    2. terraform destroy 실행
  # ---------------------------------------------------------------
  force_destroy = false

  # ---------------------------------------------------------------
  # 수명 주기 정책 (Lifecycle)
  # assets: false — 정적 자산은 장기 보존 (삭제 자동화 불필요)
  # logs:   true  — 오래된 로그는 자동 삭제/아카이브
  # backup: true  — 백업 파일은 수명 주기 관리 필요
  # ---------------------------------------------------------------
  enable_lifecycle = false
}
