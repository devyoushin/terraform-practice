### =============================================================================
### prod/ecr/api/terragrunt.hcl
### PROD 환경 ECR — API 서버 컨테이너 레지스트리
###
### 역할: API 서버(api) Docker 이미지 저장소
###   - 마이크로서비스 아키텍처에서 API 서버용 독립 레지스트리
###   - app 레지스트리와 동일한 보안 설정 적용
###
### PROD 특징:
###   - image_tag_mutability = "IMMUTABLE"  (태그 불변성)
###   - force_delete = false                (레지스트리 보호)
###   - scan_on_push = true                 (취약점 자동 스캔)
###   - lifecycle_policy_count = 30         (최신 30개 보존)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ IMMUTABLE 태그: Git SHA 또는 SemVer 태그 전략 필수
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../ecr/modules/ecr"
}

inputs = {
  # ---------------------------------------------------------------
  # 레지스트리 식별자
  # 최종 레지스트리명: {project_name}-prod-api
  # 이미지 URI: {account_id}.dkr.ecr.ap-northeast-2.amazonaws.com/{name}
  # ---------------------------------------------------------------
  repository_suffix = "api"

  # ---------------------------------------------------------------
  # 이미지 태그 불변성
  # prod: IMMUTABLE — 태그 덮어쓰기 차단으로 배포 추적성 확보
  #
  # CI/CD 파이프라인 권장 설정:
  #   IMAGE_TAG=$(git rev-parse --short HEAD)
  #   docker build -t {repo}:${IMAGE_TAG} .
  #   docker push {repo}:${IMAGE_TAG}
  # ---------------------------------------------------------------
  image_tag_mutability = "IMMUTABLE"

  # ---------------------------------------------------------------
  # 강제 삭제 방지
  # prod: false — 운영 이미지 보호
  # ---------------------------------------------------------------
  force_delete = false

  # ---------------------------------------------------------------
  # 취약점 스캔
  # prod: true — 보안 취약점 조기 탐지
  # HIGH/CRITICAL CVE 발견 시 배포 차단 파이프라인 연동 권장
  # ---------------------------------------------------------------
  scan_on_push = true

  # ---------------------------------------------------------------
  # 수명 주기 정책
  # 최신 30개 이미지 보존 — 롤백 범위 확보
  # ---------------------------------------------------------------
  lifecycle_policy_count = 30
}
