### =============================================================================
### prod/ecr/app/terragrunt.hcl
### PROD 환경 ECR — 메인 애플리케이션 컨테이너 레지스트리
###
### 역할: 메인 애플리케이션(app) Docker 이미지 저장소
###   - CI/CD 파이프라인에서 빌드된 이미지를 이 레지스트리에 푸시
###   - EKS 워커 노드 / ECS 태스크에서 이 레지스트리에서 이미지 풀
###
### PROD 특징:
###   - image_tag_mutability = "IMMUTABLE"  (이미지 태그 덮어쓰기 차단)
###   - force_delete = false                (레지스트리 보호)
###   - scan_on_push = true                 (푸시 시 취약점 자동 스캔)
###   - lifecycle_policy_count = 30         (최신 30개 이미지만 보존)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ IMMUTABLE 태그: 동일 태그로 재푸시 불가 — 버전 태그 전략 필수
###    권장 태그 전략: {git_sha} 또는 {semver} (latest 태그 지양)
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../ecr/modules/ecr"
}

inputs = {
  # ---------------------------------------------------------------
  # 레지스트리 식별자
  # 최종 레지스트리명: {project_name}-prod-app
  # 이미지 URI: {account_id}.dkr.ecr.ap-northeast-2.amazonaws.com/{name}
  # ---------------------------------------------------------------
  repository_suffix = "app"

  # ---------------------------------------------------------------
  # 이미지 태그 불변성
  # prod: IMMUTABLE — 동일 태그로 이미지 덮어쓰기 차단
  #        → 배포 추적성 확보, 이미지 훼손 방지
  # dev:  MUTABLE   — 개발 중 same 태그 재사용 허용 (latest 등)
  #
  # ⚠️ IMMUTABLE 설정 시 반드시 고유한 태그 전략 사용:
  #    권장: Git SHA (git rev-parse --short HEAD)
  #    예시: docker push {repo}:{git-sha}
  # ---------------------------------------------------------------
  image_tag_mutability = "IMMUTABLE"

  # ---------------------------------------------------------------
  # 강제 삭제 방지
  # prod: false — 이미지가 있는 레지스트리 삭제 차단
  # dev:  true  — 정리 시 모든 이미지 포함 삭제 허용
  # ---------------------------------------------------------------
  force_delete = false

  # ---------------------------------------------------------------
  # 푸시 시 취약점 스캔
  # prod: true — 이미지 푸시마다 Amazon Inspector 기반 CVE 스캔
  # 스캔 결과는 ECR 콘솔 또는 CLI로 확인:
  #   aws ecr describe-image-scan-findings \
  #     --repository-name <repo> --image-id imageTag=<tag>
  # ---------------------------------------------------------------
  scan_on_push = true

  # ---------------------------------------------------------------
  # 수명 주기 정책
  # prod: 최신 30개 이미지만 보존 (오래된 이미지 자동 삭제)
  # dev:  10개 보존 (스토리지 비용 절약)
  #
  # ECR 스토리지 비용: GB당 약 $0.10/월
  # 이미지 1개 평균 약 500MB → 30개 = 약 15GB = $1.5/월
  # ---------------------------------------------------------------
  lifecycle_policy_count = 30
}
