### =============================================================================
### prod/iam/terragrunt.hcl
### PROD 환경 IAM — EC2 인스턴스 역할 및 프로파일
###
### 역할: EC2 인스턴스에 부여할 IAM Role + Instance Profile 생성
### 포함 정책:
###   - AmazonSSMManagedInstanceCore  → SSM Session Manager (SSH 대체)
###   - CloudWatch Agent              → 메트릭/로그 수집 권한
###   - S3 읽기 권한                  → 애플리케이션 아티팩트 다운로드
###
### PROD 특징:
###   - dev와 동일한 구조이나 prod 환경 태그 적용
###   - Bastion 호스트도 이 프로파일 사용 (SSM 접근용)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../iam/modules/ec2-role"
}

inputs = {
  # ---------------------------------------------------------------
  # IAM Role 식별자
  # 생성되는 역할명: {project_name}-prod-ec2-role
  # 생성되는 프로파일명: {project_name}-prod-ec2-profile
  # ---------------------------------------------------------------
  role_suffix = "ec2"

  # ---------------------------------------------------------------
  # SSM Session Manager 권한
  # prod: SSM을 통한 접근만 허용 (SSH 포트 불필요 → 공격 면적 감소)
  # Bastion 호스트 없이도 안전한 인스턴스 접근 가능
  # ---------------------------------------------------------------
  enable_ssm = true

  # ---------------------------------------------------------------
  # CloudWatch Agent 권한
  # prod: 활성화 — 상세 메트릭 및 애플리케이션 로그 수집 필수
  # ---------------------------------------------------------------
  enable_cloudwatch_agent = true

  # ---------------------------------------------------------------
  # S3 읽기 권한
  # 애플리케이션 설정 파일, 아티팩트 다운로드에 활용
  # 최소 권한 원칙: 특정 버킷 ARN으로 제한 권장
  # ---------------------------------------------------------------
  enable_s3_readonly = true
}
