### =============================================================================
### prod/cloudwatch/terragrunt.hcl
### PROD 환경 CloudWatch — 모니터링 및 알람
###
### 역할: 인프라 전체 모니터링, 알람, 대시보드 중앙 관리
###   - SNS 토픽 생성 (알람 수신용)
###   - CloudWatch 알람 설정 (CPU, 메모리, 에러율 등)
###   - CloudWatch 대시보드 생성
###   - 로그 그룹 생성 및 보존 기간 설정
###
### PROD 특징:
###   - log_retention_days = 90         (dev: 7일)
###   - enable_alarm_notification = true (알람 이메일/SMS 발송)
###   - enable_dashboard = true          (CloudWatch 대시보드 생성)
###
### 이 모듈의 outputs (다른 모듈에서 의존):
###   - alarm_topic_arn → SQS/SNS, GuardDuty, Route53 등에서 사용
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ alarm_email을 실제 알람 수신 이메일 주소로 교체 필요
### ⚠️ SNS 구독 확인 이메일이 발송됨 — 반드시 확인 클릭 필요
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../cloudwatch/modules/cloudwatch"
}

inputs = {
  # ---------------------------------------------------------------
  # 로그 보존 기간
  # prod: 90일 — 보안 감사 및 장애 분석 기간 확보
  # dev:  7일  — CloudWatch 로그 비용 절약
  #
  # 컴플라이언스 요건에 따라 조정:
  #   - ISO 27001: 최소 90일
  #   - PCI-DSS:   최소 1년
  # ---------------------------------------------------------------
  log_retention_days = 90

  # ---------------------------------------------------------------
  # 알람 알림 (SNS → 이메일/SMS/Slack)
  # prod: true — 임계값 초과 시 즉시 알람 발송
  # dev:  false — 알람 비활성화 (비용 및 노이즈 방지)
  # ---------------------------------------------------------------
  enable_alarm_notification = true

  # ---------------------------------------------------------------
  # 알람 수신 이메일
  # ⚠️ 실제 알람 수신 이메일 주소로 교체 필요!
  #
  # 배포 후 아래 이메일로 SNS 구독 확인 메일이 발송됩니다.
  # 반드시 "Confirm subscription" 링크를 클릭해야 알람 수신됩니다.
  #
  # 팀 메일함 또는 PagerDuty/OpsGenie 엔드포인트 권장
  # ---------------------------------------------------------------
  alarm_email = "REPLACE_WITH_ALARM_EMAIL"

  # ---------------------------------------------------------------
  # CloudWatch 대시보드
  # prod: true — 인프라 전체 현황을 한눈에 파악하는 대시보드 생성
  # 대시보드 포함 위젯:
  #   - EC2 CPU/네트워크 사용률
  #   - RDS 연결 수 / CPU / 스토리지
  #   - ALB 요청 수 / 에러율 / 응답 시간
  #   - ElastiCache 히트율 / 메모리 사용량
  # ---------------------------------------------------------------
  enable_dashboard = true

  # ---------------------------------------------------------------
  # 알람 임계값 설정
  # prod: 엄격한 임계값 (조기 탐지)
  # ---------------------------------------------------------------
  cpu_alarm_threshold      = 80   # CPU 사용률 80% 초과 시 알람
  memory_alarm_threshold   = 80   # 메모리 사용률 80% 초과 시 알람
  disk_alarm_threshold     = 85   # 디스크 사용률 85% 초과 시 알람
  error_rate_threshold     = 5    # 에러율 5% 초과 시 알람
}
