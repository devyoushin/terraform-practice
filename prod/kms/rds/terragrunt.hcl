### =============================================================================
### prod/kms/rds/terragrunt.hcl
### PROD 환경 KMS 키 — RDS 암호화용
###
### 역할: RDS 인스턴스 저장 데이터 암호화에 사용할 KMS CMK(고객 관리형 키) 생성
### PROD 특징:
###   - deletion_window_in_days = 30 (dev: 7일)
###     → 실수로 인한 키 삭제 시 30일 이내 복구 가능
###   - enable_key_rotation = true (연간 자동 키 교체)
###     → 보안 컴플라이언스(PCI-DSS, HIPAA, ISO 27001) 요구사항 충족
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ KMS 키 삭제 시 암호화된 RDS 데이터 복구 불가 — 절대 주의!
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../kms/modules/kms"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 키 식별자
  # 생성되는 별칭: alias/{project_name}-prod-rds
  # RDS 인스턴스 생성 시 이 키 ARN을 storage_encrypted_kms_key_id 에 지정
  # ---------------------------------------------------------------
  key_suffix = "rds"

  # ---------------------------------------------------------------
  # 키 삭제 대기 기간
  # prod: 30일 — 실수로 인한 삭제 시 30일 이내 복구 가능
  # dev:  7일  — 개발 환경에서 빠른 정리를 위해 최솟값 사용
  #
  # ⚠️ KMS 키가 삭제되면 해당 키로 암호화된 모든 데이터는
  #    영구적으로 복호화 불가능 → 반드시 30일 대기 기간 유지
  # ---------------------------------------------------------------
  deletion_window_in_days = 30

  # ---------------------------------------------------------------
  # 키 교체 (Key Rotation)
  # prod: true  — 연간 자동 교체 (보안 컴플라이언스 필수)
  # dev:  false — 테스트 목적으로 비활성화
  #
  # 자동 교체 시 기존 암호화 데이터는 그대로 복호화 가능
  # (AWS가 이전 키 버전을 내부적으로 유지)
  # ---------------------------------------------------------------
  enable_key_rotation = true
}
