### =============================================================================
### prod/kms/s3/terragrunt.hcl
### PROD 환경 KMS 키 — S3 버킷 암호화용
###
### 역할: S3 버킷 서버사이드 암호화(SSE-KMS)에 사용할 KMS CMK 생성
### 이 키는 S3 외에도 다음 서비스에서 공통으로 활용됩니다:
###   - ElastiCache 암호화
###   - SQS/SNS 메시지 암호화
###   - Secrets Manager 시크릿 암호화
###   - Backup Vault 암호화
###
### PROD 특징:
###   - deletion_window_in_days = 30 (dev: 7일)
###   - enable_key_rotation = true (보안 컴플라이언스)
###
### ⚠️ PROD 환경: 배포 전 반드시 plan 검토
### ⚠️ 이 키는 여러 서비스에서 공유 — 삭제 시 다수 서비스 영향!
### =============================================================================

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "../../../kms/modules/kms"
}

prevent_destroy = true  # Terragrunt: run-all destroy 실행 차단

inputs = {
  # ---------------------------------------------------------------
  # 키 식별자
  # 생성되는 별칭: alias/{project_name}-prod-s3
  # S3 버킷, ElastiCache, SQS/SNS, Backup Vault 등에서 공통 사용
  # ---------------------------------------------------------------
  key_suffix = "s3"

  # ---------------------------------------------------------------
  # 키 삭제 대기 기간
  # prod: 30일 — 실수로 인한 삭제 시 복구 기간 확보
  # dev:  7일  — 신속한 환경 정리 가능
  #
  # ⚠️ 이 키로 암호화된 S3 객체 / SQS 메시지 / 시크릿 등
  #    키 삭제 시 모두 복호화 불가 → 절대 경솔하게 삭제 금지
  # ---------------------------------------------------------------
  deletion_window_in_days = 30

  # ---------------------------------------------------------------
  # 키 교체 (Key Rotation)
  # prod: true — 연간 자동 교체 (AWS 보안 권고 및 컴플라이언스 충족)
  # 교체 후에도 기존 암호화 데이터는 정상 복호화 가능
  # ---------------------------------------------------------------
  enable_key_rotation = true
}
